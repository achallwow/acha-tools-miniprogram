<!-- pages/index/index.wxml -->
<scroll-view
  class="scroll-wrapper"
  scroll-y="{{!isDragging}}"
  enhanced="{{false}}"
  show-scrollbar="{{false}}"
  fast-deceleration="{{true}}"
>
  <view class="global-page-container">
    <!-- 返回按钮 -->
    <view
      class="floating-back-btn"
      bindtap="onBackTap"
    >
      <view class="back-icon"></view>
    </view>

    <view class="grid-box">
      <!-- 标题区域 -->
      <view class="top-box">
        <input
          class="title-input"
          placeholder="输入标题"
          value="{{title}}"
          bindinput="onTitleInput"
          maxlength="30"
        />
        <view class="date-text">{{currentDate}}</view>
      </view>

      <!-- 九宫格 -->
      <view class="grid-container">
        <view
          class="grid-slot"
          wx:for="{{gridSlots}}"
          wx:key="*this"
          wx:for-item="slotNum"
          data-slot="{{slotNum}}"
        >
          <!-- 找到对应 slot 的 item -->
          <block wx:for="{{gridItems}}" wx:key="id" wx:for-item="item">
            <view
              wx:if="{{item.slot === slotNum}}"
              class="grid-item {{isDragging && dragId === item.id ? 'dragging' : ''}}"
              data-index="{{slotNum}}"
              data-id="{{item.id}}"
              bindtouchstart="onDragStart"
              catchtouchmove="onDragMove"
              catchtouchend="onDragEnd"
              bindtap="onGridItemTap"
            >
              <!-- Logo 格子 -->
              <block wx:if="{{item.id === 'logo'}}">
                <image
                  wx:if="{{currentLogoIndex !== -1}}"
                  class="item-image"
                  src="{{logoList[currentLogoIndex]}}"
                  mode="aspectFill"
                />
                <view wx:else class="logo-text">LOGO</view>
              </block>

              <!-- 普通格子 -->
              <block wx:else>
                <image
                  wx:if="{{item.src}}"
                  class="item-image"
                  src="{{item.src}}"
                  mode="aspectFill"
                />
                <view wx:else class="add-icon">+</view>

                <!-- 删除按钮 -->
                <view
                  wx:if="{{item.src}}"
                  class="delete-btn"
                  catchtap="deleteImage"
                  data-id="{{item.id}}"
                >×</view>
              </block>
            </view>
          </block>
        </view>
      </view>

      <!-- 拖拽时的跟随元素 -->
      <view
        wx:if="{{isDragging}}"
        class="drag-ghost"
        style="left: {{dragX}}px; top: {{dragY}}px;"
      >
        <image src="{{dragSrc}}" mode="aspectFill"/>
      </view>

      <view class="bottom-slogan">专注您的生活</view>
    </view>

    <!-- 品牌签名 -->
    <view class="brand-signature-container">
      <text class="brand-signature">VANSUN</text>
    </view>

    <!-- 按钮 -->
    <view class="btn-box">
      <button bindtap="chooseMultipleImages" class="action-btn secondary" disabled="{{!hasEmptySlot}}">多选</button>
      <button bindtap="saveGridImage" class="action-btn">保存</button>
    </view>

    <!-- Logo 选择器 -->
    <view class="logo-picker-mask" wx:if="{{showLogoPicker}}" catchtap="closeLogoPicker">
      <view class="logo-picker-content" catchtap="noop">
        <view class="picker-title">选择Logo</view>
        <view class="logo-list">
          <view
            class="logo-item {{currentLogoIndex === index ? 'active' : ''}}"
            wx:for="{{logoList}}"
            wx:key="index"
            data-logo-index="{{index}}"
            bindtap="selectLogo"
          >
            <image src="{{item}}" mode="aspectFill"/>
          </view>
        </view>
        <view class="picker-close" bindtap="closeLogoPicker">关闭</view>
      </view>
    </view>

    <canvas type="2d" id="gridCanvas" class="canvas-hide"/>
  </view>
</scroll-view>
